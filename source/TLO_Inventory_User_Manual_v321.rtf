Full inventory}
\par \pard\plain \s81\rtlch\af14\afs22\alang1025 \ltrch\lang1033\langfe1033\hich\af9\loch\sl276\slmult1\ql\widctlpar\li360\lin360\ri144\rin144\sb40\sa80\ltrpar\hyphpar0\f9\fs17\cf0\lang1033\kerning0\dbch\af13\langfe1033\sb60\sa120{\loch
Windows:\line C:\\TLOHome\\apps\\Windows\\tlo-gi.exe --TLOHome C:\\TLOHome\line C:\\TLOHome\\apps\\Windows\\tlo-gi.exe --TLOHome C:\\TLOHome --search-path "[Backup-1]E:\\Music" --performance-mode fast\line \line WSL/Linux:\line "$TLOHome/apps/Linux/tlo-gi" --TLOHome "$TLOHome"\line "$TLOHome/apps/Linux/tlo-gi" --TLOHome "$TLOHome" --search-path "[Backup-1]/mnt/e/Music" --etree-lookup\line \line Single path with per-path directives:\line C:\\TLOHome\\apps\\Windows\\tlo-gi.exe --TLOHome C:\\TLOHome --search-path "[Backup-1]E:\\Music" --$copy F:\\TaggedCopies\line C:\\TLOHome\\apps\\Windows\\tlo-gi.exe --TLOHome C:\\TLOHome --search-path "[Archive-H]H:\\Incoming" --$copy-delete I:\\TaggedFinished --$slam "Bob Dylan"}
\par \pard\plain \s2\rtlch\af14\afs26\ab \ltrch\hich\af8\loch\keep\sb200\sa0\keepn\cf18\f8\fs26\b\dbch\af10{\loch
