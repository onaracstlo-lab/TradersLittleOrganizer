\par \pard\plain \s76\loch\sl240\slmult1\sb0\sa200\contextualspace{\listtext\pard\plain \rtlch\af12 \ltrch \u61623\'3f\tab}\ilvl0\ls1 \fi-360\li360\lin360\sl240\slmult1{\hich\af7\loch\f7\loch
