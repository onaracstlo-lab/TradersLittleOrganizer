\par \pard\plain \s0\rtlch\af12\afs22\alang1025 \ltrch\lang1033\langfe1033\hich\af2\loch\sl276\slmult1\ql\widctlpar\hyphpar0\sb0\sa200\ltrpar\cf0\f2\fs20\lang1033\kerning0\dbch\af10\langfe1033\sl276\slmult1\fi-360\li360\lin360\sb0\sa0{\loch
5.\tab Open a new Windows terminal or restart any already-open TLO app so the changed environment is visible.}
\par \pard\plain \s90\rtlch\af12\afs22\alang1025 \ltrch\lang1033\langfe1033\hich\af8\loch\sl276\slmult1\ql\widctlpar\hyphpar0\li360\lin360\ri144\rin144\sb40\sa80\ltrpar\cf0\f8\fs17\lang1033\kerning0\dbch\af13\langfe1033\sl276\slmult1\fi0\li360\lin360\ri144\rin144\sb60\sa120{\loch
